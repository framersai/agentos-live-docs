{
  "name": "@wunderland/demo-video",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts DemoVideo out/demo.mp4 --codec h264",
    "render:webm": "remotion render src/index.ts DemoVideo out/demo.webm --codec vp8",
    "render:poster": "remotion still src/index.ts DemoVideo out/demo-poster.jpg --frame=75",
    "deploy": "cp out/demo.mp4 ../wunderland-sh-site/public/demo.mp4 && cp out/demo-poster.jpg ../wunderland-sh-site/public/demo-poster.jpg"
  },
  "dependencies": {
    "@remotion/animation-utils": "4.0.431",
    "@remotion/cli": "4.0.431",
    "@remotion/google-fonts": "4.0.431",
    "@remotion/paths": "4.0.431",
    "@remotion/transitions": "4.0.431",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.431"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
