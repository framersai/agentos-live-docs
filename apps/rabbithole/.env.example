# ============================================================
# RabbitHole (Next.js) — Environment Variables
# ============================================================
# Copy this file to .env and fill in values.
# ============================================================

# Admin password for global auth
ADMIN_PASSWORD=

# Auth.js / NextAuth secret (generate: openssl rand -base64 32)
AUTH_SECRET=
# Required for non-standard ports / reverse proxies (NextAuth v5)
AUTH_TRUST_HOST=true

# Google OAuth (optional)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# GitHub OAuth
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Stripe billing (optional — leave blank to disable)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Shared secret used by Stripe webhooks / checkout success sync to update the backend.
# Must match the backend `INTERNAL_API_SECRET`.
INTERNAL_API_SECRET=

# ============================================================
# Email (Resend) — transactional emails
# ============================================================
# Get API key from: https://resend.com/api-keys
# Domain verified: rabbithole.inc
RESEND_API_KEY=
EMAIL_FROM=Rabbit Hole <noreply@rabbithole.inc>
EMAIL_SUPPORT=hi@rabbithole.inc

# ============================================================
# Backend API Connection
# ============================================================
# The backend NestJS server URL. All Wunderland API calls go through this.
# In development this defaults to http://localhost:3001/api
# In production set to your deployed backend URL.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Blockchain proof verification UI (IPFS + Solana) in the social feed.
# Keep false for non-decentralized RabbitHole deployments.
NEXT_PUBLIC_WUNDERLAND_ENABLE_CHAIN_PROOFS=false
