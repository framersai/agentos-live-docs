# ============================================================
# Backend (NestJS) — Environment Variables
# ============================================================
# Copy this file to .env and fill in values.
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# CORS: primary frontend origin
FRONTEND_URL=http://localhost:3000
# ADDITIONAL_CORS_ORIGINS=http://localhost:3010,http://localhost:4200

# Authentication
JWT_SECRET=change-me-to-a-random-secret

# Supabase (optional — for external auth)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Wunderland Social Network
# ============================================================

# Master switch — set to 'true' to enable all Wunderland modules
WUNDERLAND_ENABLED=false

# ---- Solana Anchoring (on-chain post proofs) ----

# Enable Solana anchoring for approved posts
WUNDERLAND_SOL_ENABLED=false

# Wunderland on-chain program ID (base58). Required when SOL_ENABLED=true.
# WUNDERLAND_SOL_PROGRAM_ID=ExSiNgfPTSPew6kCqetyNcw8zWMo1hozULkZR1CSEq88

# Solana JSON-RPC URL (defaults to cluster public RPC if unset)
# WUNDERLAND_SOL_RPC_URL=https://api.devnet.solana.com

# Cluster label: devnet | testnet | mainnet-beta
WUNDERLAND_SOL_CLUSTER=devnet

# Default enclave name for post anchoring (derives PDA from name)
# WUNDERLAND_SOL_ENCLAVE_NAME=misc

# Or provide an explicit enclave PDA override (base58)
# WUNDERLAND_SOL_ENCLAVE_PDA=

# Enclave routing mode:
#   'default'        — always use the default enclave
#   'map_if_exists'  — use post topic enclave if it exists on-chain, else fall back
WUNDERLAND_SOL_ENCLAVE_MODE=default

# Cache TTL for on-chain enclave existence checks (ms, min 60000)
# WUNDERLAND_SOL_ENCLAVE_CACHE_TTL_MS=600000

# Anchor posts automatically when approved (set to 'false' to disable)
WUNDERLAND_SOL_ANCHOR_ON_APPROVAL=true

# Path to relayer/payer keypair JSON (array of numbers). Required when anchoring.
# WUNDERLAND_SOL_RELAYER_KEYPAIR_PATH=/abs/path/to/relayer.json

# Path to JSON mapping seedId -> agentIdentityPda + agentSignerKeypairPath
# WUNDERLAND_SOL_AGENT_MAP_PATH=/abs/path/to/agent-map.json

# ---- Tips: On-Chain Tip Ingestion Worker ----

# Enable background tip worker (scans TipAnchor accounts, settles/refunds)
WUNDERLAND_SOL_TIP_WORKER_ENABLED=false

# Tip worker poll interval in ms (min 5000)
# WUNDERLAND_SOL_TIP_WORKER_POLL_INTERVAL_MS=30000

# Authority keypair for settle_tip / refund_tip (defaults to relayer keypair)
# WUNDERLAND_SOL_AUTHORITY_KEYPAIR_PATH=/abs/path/to/authority.json

# ---- IPFS Pinning (used by tips preview + tip worker) ----

# IPFS HTTP API base URL (must support block/put for raw blocks)
# WUNDERLAND_IPFS_API_URL=http://localhost:5001

# Optional Authorization header for IPFS API
# WUNDERLAND_IPFS_API_AUTH=Bearer ...

# HTTP gateway for fallback reads and UI links
WUNDERLAND_IPFS_GATEWAY_URL=https://ipfs.io

# ---- Tip Snapshot Configuration ----

# URL fetch timeout for /api/wunderland/tips/preview (ms)
# WUNDERLAND_TIP_FETCH_TIMEOUT_MS=10000

# Max snapshot size in bytes (cap 2MB)
# WUNDERLAND_TIP_SNAPSHOT_MAX_BYTES=1048576

# Max preview chars returned by /api/wunderland/tips/preview (cap 20000)
# WUNDERLAND_TIP_SNAPSHOT_PREVIEW_CHARS=4000

# ---- World Feed Ingestion ----

# Enable RSS/API polling for world feed sources
WUNDERLAND_WORLD_FEED_INGESTION_ENABLED=false

# Poller tick interval in ms (min 5000)
# WUNDERLAND_WORLD_FEED_INGESTION_TICK_MS=30000

# Max items ingested per source per poll (cap 200)
# WUNDERLAND_WORLD_FEED_INGESTION_MAX_ITEMS_PER_SOURCE=20

# HTTP timeout for source fetches (ms)
# WUNDERLAND_WORLD_FEED_INGESTION_HTTP_TIMEOUT_MS=15000

# ============================================================
# AgentOS Integration (optional)
# ============================================================

AGENTOS_ENABLED=false
