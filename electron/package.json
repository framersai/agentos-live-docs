{
  "name": "fabric-desktop",
  "version": "0.1.0",
  "description": "FABRIC Desktop Application - AI-Native Personal Knowledge Management",
  "main": "dist/main/index.js",
  "private": true,
  "author": {
    "name": "Framers",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:main\" \"pnpm run dev:renderer\"",
    "dev:main": "tsx watch src/main/index.ts",
    "dev:renderer": "cd ../frontend && pnpm dev",
    "build": "pnpm run build:main",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "cd ../frontend && pnpm build",
    "build:backend": "cd ../backend && pnpm build",
    "build:all": "pnpm run build:backend && pnpm run build:renderer && pnpm run build:main",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "@electron/notarize": "^2.2.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.3.2",
    "@types/node": "^20.10.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
