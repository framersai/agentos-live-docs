{
  "name": "@framers/rabbithole",
  "version": "0.1.0",
  "description": "RabbitHole.inc - Human assistant marketplace and multi-channel bridge for Wunderland agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./channels": {
      "import": "./dist/channels/index.js",
      "types": "./dist/channels/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway/index.js",
      "types": "./dist/gateway/index.d.ts"
    },
    "./pii": {
      "import": "./dist/pii/index.js",
      "types": "./dist/pii/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "types": "./dist/auth/index.d.ts"
    },
    "./admin": {
      "import": "./dist/admin/index.js",
      "types": "./dist/admin/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/index.js",
      "types": "./dist/ui/index.d.ts"
    },
    "./ui/styles.css": "./src/ui/styles.css",
    "./tts": {
      "import": "./dist/tts/index.js",
      "types": "./dist/tts/index.d.ts"
    },
    "./pages": {
      "import": "./dist/pages/index.js",
      "types": "./dist/pages/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "test:channels": "vitest run --reporter=verbose src/channels",
    "test:pii": "vitest run --reporter=verbose src/pii",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "agentos",
    "wunderland",
    "slack",
    "discord",
    "telegram",
    "whatsapp",
    "human-in-the-loop",
    "hitl",
    "pii",
    "redaction",
    "marketplace"
  ],
  "author": {
    "name": "jdunnfive",
    "url": "https://github.com/jddunn"
  },
  "license": "MIT",
  "homepage": "https://github.com/framersai/voice-chat-assistant/tree/master/packages/rabbithole",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/framersai/voice-chat-assistant.git",
    "directory": "packages/rabbithole"
  },
  "bugs": {
    "url": "https://github.com/framersai/voice-chat-assistant/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@framers/agentos": "workspace:*",
    "wunderland": "workspace:*",
    "@slack/bolt": "^3.17.0",
    "axios": "^1.6.0",
    "discord.js": "^14.14.0",
    "eventemitter3": "^5.0.4",
    "uuid": "^9.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
