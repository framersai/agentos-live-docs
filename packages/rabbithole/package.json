{
  "name": "@framers/rabbithole",
  "version": "0.1.0",
  "description": "RabbitHole.inc - Human assistant marketplace and multi-channel bridge for Wunderland agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./channels": {
      "import": "./dist/channels/index.js",
      "types": "./dist/channels/index.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway/index.js",
      "types": "./dist/gateway/index.d.ts"
    },
    "./pii": {
      "import": "./dist/pii/index.js",
      "types": "./dist/pii/index.d.ts"
    },
    "./permissions": {
      "import": "./dist/permissions/index.js",
      "types": "./dist/permissions/index.d.ts"
    },
    "./approval": {
      "import": "./dist/approval/index.js",
      "types": "./dist/approval/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "types": "./dist/auth/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest",
    "test:channels": "vitest run --reporter=verbose src/channels",
    "test:pii": "vitest run --reporter=verbose src/pii",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "agentos",
    "wunderland",
    "slack",
    "discord",
    "telegram",
    "whatsapp",
    "human-in-the-loop",
    "hitl",
    "pii",
    "redaction",
    "marketplace"
  ],
  "author": {
    "name": "jdunnfive",
    "url": "https://github.com/jddunn"
  },
  "license": "MIT",
  "homepage": "https://github.com/jddunn/wunderland",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jddunn/wunderland.git"
  },
  "bugs": {
    "url": "https://github.com/jddunn/wunderland/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@framers/agentos": "workspace:*",
    "@framers/wunderland": "workspace:*",
    "@slack/bolt": "^3.17.0",
    "axios": "^1.6.0",
    "discord.js": "^14.14.0",
    "eventemitter3": "^5.0.4",
    "uuid": "^9.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}