{
  "name": "@framers/agentos-extensions-registry",
  "version": "0.1.0",
  "description": "Curated extension registry bundle for AgentOS — single import to register channels, tools, and integrations",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/agentos-extensions-registry.git"
  },
  "keywords": [
    "agentos",
    "extensions",
    "registry",
    "channels",
    "tools"
  ],
  "author": {
    "name": "Framers AI",
    "email": "team@frame.dev",
    "url": "https://frame.dev"
  },
  "license": "MIT",
  "peerDependencies": {
    "@framers/agentos": "workspace:*"
  },
  "optionalDependencies": {
    "@framers/agentos-ext-auth": "workspace:*",
    "@framers/agentos-ext-web-search": "workspace:*",
    "@framers/agentos-ext-web-browser": "workspace:*",
    "@framers/agentos-ext-telegram": "workspace:*",
    "@framers/agentos-ext-cli-executor": "workspace:*",
    "@framers/agentos-ext-giphy": "workspace:*",
    "@framers/agentos-ext-image-search": "workspace:*",
    "@framers/agentos-ext-voice-synthesis": "workspace:*",
    "@framers/agentos-ext-news-search": "workspace:*",
    "@framers/agentos-ext-channel-telegram": "workspace:*",
    "@framers/agentos-ext-channel-whatsapp": "workspace:*",
    "@framers/agentos-ext-channel-discord": "workspace:*",
    "@framers/agentos-ext-channel-slack": "workspace:*",
    "@framers/agentos-ext-channel-webchat": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^1.0.0"
  }
}
