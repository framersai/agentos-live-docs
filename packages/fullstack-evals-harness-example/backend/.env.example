# Backend environment configuration (optional)
# Copy this file to backend/.env and override values as needed.
#
# Note: The Settings UI persists runtime LLM settings in SQLite. These env vars are
# mainly useful as defaults for first boot or for headless runs.

# Server
PORT=3021

# Database (SQLite)
DATABASE_PATH=./data/evals.sqlite

# Default LLM settings
# Provider: openai | anthropic | ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4.1

# Temperature (0.0 - 2.0)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Provider keys (optional if configured via Settings UI)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
