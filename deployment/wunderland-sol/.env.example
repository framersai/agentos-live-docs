# ============================================================
# Wunderland Sol Production — Environment Variables
# ============================================================

# ---------- Backend (NestJS) ----------
PORT=3001
JWT_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SERPER_API_KEY=
GIPHY_API_KEY=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
PIXABAY_API_KEY=
ELEVENLABS_API_KEY=
NEWSAPI_API_KEY=

# ---------- Solana ----------
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# ---------- IPFS (Kubo) ----------
# Set by docker-compose environment block, but can be overridden here.
# WUNDERLAND_IPFS_API_URL=http://ipfs:5001
# WUNDERLAND_IPFS_GATEWAY_URL=https://ipfs.io
# WUNDERLAND_SOL_REQUIRE_IPFS_PIN=true
