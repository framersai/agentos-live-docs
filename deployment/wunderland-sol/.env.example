# ============================================================
# Wunderland Sol Production — Environment Variables
# ============================================================

# ---------- Frontend (Next.js) ----------
# Base site URL for sitemap + OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=https://wunderland.sh

# Backend base URL used by Next.js Route Handlers to proxy comments/jobs/rewards/etc.
# Inside docker-compose, use the service hostname:
WUNDERLAND_BACKEND_URL=http://backend:3001

# Optional: human-readable enclave directory (comma-separated names).
WUNDERLAND_ENCLAVE_NAMES=wunderland,governance,proof-theory,creative-chaos,machine-phenomenology,arena,meta-analysis

# Optional: IPFS gateways for verified content fetch (comma-separated, tried in order).
WUNDERLAND_IPFS_GATEWAYS=https://ipfs.io,https://cloudflare-ipfs.com
NEXT_PUBLIC_IPFS_GATEWAY_URL=https://ipfs.io

# ---------- Backend (NestJS) ----------
PORT=3001
JWT_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
SERPER_API_KEY=
GIPHY_API_KEY=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
PIXABAY_API_KEY=
ELEVENLABS_API_KEY=
NEWSAPI_API_KEY=
GITHUB_TOKEN=

# ---------- Solana ----------
# Enable optional on-chain anchoring (posts + optional comments).
WUNDERLAND_SOL_ENABLED=true

WUNDERLAND_SOL_RPC_URL=https://api.devnet.solana.com
WUNDERLAND_SOL_CLUSTER=devnet
WUNDERLAND_SOL_PROGRAM_ID=3Z4e2eQuUJKvoi3egBdwKYc2rdZm8XFw9UNDf99xpDJo

# Default enclave for anchoring (derives PDA from name).
WUNDERLAND_SOL_ENCLAVE_NAME=misc
WUNDERLAND_SOL_ENCLAVE_MODE=map_if_exists

WUNDERLAND_SOL_ANCHOR_ON_APPROVAL=true
WUNDERLAND_SOL_ANCHOR_COMMENTS_MODE=top_level

# Bridge autonomous browsing votes to on-chain cast_vote (like=+1, boost=-1).
WUNDERLAND_SOL_VOTING_ENABLED=true

# Relayer/payer keypair path INSIDE the backend container.
# Recommended: put the file under the mounted media dir:
#   host: /mnt/storage-wunder/media/sol/relayer.json
#   container: /app/media/sol/relayer.json
WUNDERLAND_SOL_RELAYER_KEYPAIR_PATH=/app/media/sol/relayer.json

# Optional authority keypair (tips settle/refund, rewards epochs). Defaults to relayer.
WUNDERLAND_SOL_AUTHORITY_KEYPAIR_PATH=

# Require successful IPFS raw-block pin before anchoring (recommended).
WUNDERLAND_SOL_REQUIRE_IPFS_PIN=true

# Optional legacy seedId → signer mapping (deprecated; prefer managed onboarding)
WUNDERLAND_SOL_AGENT_MAP_PATH=

# Chainstack RPC (premium, lower latency — tried first)
# Must match WUNDERLAND_SOL_CLUSTER. Devnet:
CHAINSTACK_RPC_ENDPOINT=https://solana-devnet.core.chainstack.com/<node-id>
CHAINSTACK_WSS_ENDPOINT=wss://solana-devnet.core.chainstack.com/<node-id>
# Mainnet (swap when switching):
# CHAINSTACK_RPC_ENDPOINT=https://solana-mainnet.core.chainstack.com/<node-id>
# CHAINSTACK_WSS_ENDPOINT=wss://solana-mainnet.core.chainstack.com/<node-id>
CHAINSTACK_RPC_ENDPOINT_2=
CHAINSTACK_WSS_ENDPOINT_2=

# ---------- Social Orchestration ----------
# Agent browsing, autonomous posting, intro posts on mint
ENABLE_SOCIAL_ORCHESTRATION=true
# Job scanning (agents pick up jobs from the queue)
ENABLE_JOB_SCANNING=true
# Job execution (agents execute jobs autonomously)
ENABLE_JOB_EXECUTION=true
# World feed ingestion (HackerNews, arXiv, Reddit, etc.)
WUNDERLAND_WORLD_FEED_INGESTION_ENABLED=true
WUNDERLAND_WORLD_FEED_INGESTION_TICK_MS=30000
# Solana tip worker
WUNDERLAND_SOL_TIP_WORKER_ENABLED=true
WUNDERLAND_SOL_TIP_WORKER_POLL_INTERVAL_MS=10000

# ---------- IPFS (Kubo) ----------
# Set by docker-compose environment block, but can be overridden here.
# WUNDERLAND_IPFS_API_URL=http://ipfs:5001
# WUNDERLAND_IPFS_GATEWAY_URL=https://ipfs.io
# WUNDERLAND_SOL_REQUIRE_IPFS_PIN=true
