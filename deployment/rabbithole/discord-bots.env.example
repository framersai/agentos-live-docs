# Discord Bot Tokens (REQUIRED)
WUNDERBOT_NEWS_TOKEN=
WUNDERBOT_AGENT_TOKEN=
DISCORD_GUILD_ID=1470346554341855272

# Scraper API
SCRAPER_API_PORT=8420

# Wunderland feed integration
WUNDERLAND_FEED_URL=http://host.docker.internal:3001/api/feed
WUNDERLAND_FEED_SECRET=
WUNDERLAND_URL=http://host.docker.internal:3000
WUNDERLAND_TOOL_API_KEY=

# LLM Provider: "openai" or "ollama"
LLM_PROVIDER=openai
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Database & Timezone
RABBITHOLE_DB_PATH=./data/rabbithole.db
RABBITHOLE_TZ=America/Los_Angeles

# Async posting queue
WUNDERBOT_ASYNC_POST_QUEUE=true
WUNDERBOT_POST_QUEUE_MAX_SIZE=2000

# Optional: LinkedIn cookie for jobs scraper
LINKEDIN_COOKIE=

# Optional: Infura for Uniswap sniper
INFURA_KEY=

# Optional: Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
