# syntax=docker/dockerfile:1

# RabbitHole Next.js 16 frontend — monorepo workspace build.

FROM node:22-bookworm-slim AS builder

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@10.15.1 --activate

# Copy the full workspace (filtered by .dockerignore).
COPY . .

RUN pnpm install --no-frozen-lockfile

# NEXT_PUBLIC_* vars must be present at build time for Next.js to inline them.
ARG NEXT_PUBLIC_OAUTH_GOOGLE=true
ARG NEXT_PUBLIC_OAUTH_GITHUB=true
ARG NEXT_PUBLIC_API_URL=/api
ENV NEXT_PUBLIC_OAUTH_GOOGLE=$NEXT_PUBLIC_OAUTH_GOOGLE
ENV NEXT_PUBLIC_OAUTH_GITHUB=$NEXT_PUBLIC_OAUTH_GITHUB
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NODE_OPTIONS="--max-old-space-size=3584"

# Build workspace dependencies in dependency order (separate RUN for layer caching)
RUN pnpm --filter @framers/shared build \
 && pnpm --filter @framers/sql-storage-adapter build \
 && pnpm --filter @framers/agentos build \
 && pnpm --filter @framers/agentos-extensions-registry build \
 && pnpm --filter @framers/agentos-ext-web-search build \
 && pnpm --filter @framers/agentos-ext-web-browser build \
 && pnpm --filter @framers/agentos-ext-giphy build \
 && pnpm --filter @framers/agentos-ext-image-search build \
 && pnpm --filter @framers/agentos-ext-news-search build \
 && pnpm --filter @framers/agentos-ext-voice-synthesis build \
 && pnpm --filter @framers/agentos-ext-cli-executor build \
 && pnpm --filter @framers/agentos-skills-registry build \
 && pnpm --filter @framers/agentos-ext-skills build \
 && pnpm --filter @framers/agentos-ext-http-api build \
 && pnpm --filter wunderland build \
 && pnpm --filter @wunderland/social build

# Next.js build in separate RUN — starts fresh Node process with full heap for NFT tracer
RUN pnpm --filter rabbithole build

# Resolve all symlinks in standalone output to real files so Docker COPY works.
RUN cd /repo/apps/rabbithole/.next/standalone && \
    find . -type l | while IFS= read -r lnk; do \
      target=$(readlink -f "$lnk"); \
      rm "$lnk"; \
      if [ -d "$target" ]; then cp -r "$target" "$lnk"; \
      elif [ -f "$target" ]; then mkdir -p "$(dirname "$lnk")"; cp "$target" "$lnk"; \
      fi; \
    done

# Patch: standalone tracer misses some Next.js deps in pnpm monorepo.
# Also patch extension packages loaded via dynamic import() in the registry.
RUN STANDALONE=/repo/apps/rabbithole/.next/standalone/apps/rabbithole/node_modules && \
    for pkg in @swc/helpers @next/env caniuse-lite postcss \
      @framers/agentos-extensions-registry @framers/agentos \
      @framers/agentos-ext-web-search @framers/agentos-ext-giphy \
      @framers/agentos-ext-image-search @framers/agentos-ext-news-search \
      @framers/agentos-ext-voice-synthesis @framers/agentos-ext-cli-executor \
      @framers/agentos-ext-web-browser @framers/agentos-ext-skills \
      @framers/agentos-skills-registry; do \
      if [ ! -d "$STANDALONE/$pkg" ]; then \
        SRC="/repo/node_modules/$pkg"; \
        if [ -d "$SRC" ] || [ -L "$SRC" ]; then \
          mkdir -p "$STANDALONE/$(dirname $pkg)"; \
          cp -rL "$SRC" "$STANDALONE/$pkg"; \
          echo "Patched missing dep: $pkg"; \
        fi; \
      fi; \
    done

# Fix turbopack hashed external references (Next.js 16 appends content hashes to external names)
RUN APP_NEXT=/repo/apps/rabbithole/.next && \
    STANDALONE_NM=/repo/apps/rabbithole/.next/standalone/apps/rabbithole/node_modules && \
    if [ -f "$APP_NEXT/turbopack" ]; then \
      echo "Turbopack build — fixing hashed external references..."; \
      for hashed in $(grep -ohr '@framers/[a-z0-9_-]*-[a-f0-9]\{12,\}' "$APP_NEXT/server/chunks/" 2>/dev/null | sort -u); do \
        base=$(echo "$hashed" | sed 's/-[a-f0-9]\{12,\}$//' | sed 's|@framers/||'); \
        hashed_name=$(echo "$hashed" | sed 's|@framers/||'); \
        if [ -d "$STANDALONE_NM/@framers/$base" ] && [ ! -e "$STANDALONE_NM/@framers/$hashed_name" ]; then \
          ln -sfn "$base" "$STANDALONE_NM/@framers/$hashed_name"; \
          echo "Linked: @framers/$hashed_name -> @framers/$base"; \
        fi; \
      done; \
    fi

# -----------------------------------------------------------------------------

FROM node:22-bookworm-slim

ENV NODE_ENV=production
WORKDIR /app

COPY --from=builder /repo/apps/rabbithole/.next/standalone ./
COPY --from=builder /repo/apps/rabbithole/.next/static ./apps/rabbithole/.next/static
COPY --from=builder /repo/apps/rabbithole/public ./apps/rabbithole/public

EXPOSE 3010

CMD ["node", "apps/rabbithole/server.js"]
