# Wunderland AI Agent — Environment Configuration
# Copy to /etc/rabbithole/wunderland-agent.env on the server

# Discord (REQUIRED — same bot as wunderbot-agent, only one can run)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=1470346554341855272

# Wunderland News bot (separate identity for feed posting)
# If not set, feeds post under DISCORD_BOT_TOKEN identity
WUNDERBOT_NEWS_TOKEN=

# LLM Provider (REQUIRED)
OPENAI_API_KEY=

# RabbitHole Backend (for /verify command)
RABBITHOLE_API_URL=http://localhost:3001
RABBITHOLE_API_SECRET=
RABBITHOLE_FRONTEND_URL=https://rabbithole.inc

# Database & Storage
RABBITHOLE_DB_PATH=/mnt/storage/wunderland-agent/data/rabbithole.db
RABBITHOLE_TZ=America/Los_Angeles

# SearXNG (metasearch for /search, /ask web results)
SEARXNG_URL=http://localhost:8080

# Wunderland Agent HTTP server
PORT=3777

# Role names (defaults shown — override if different)
# ROLE_EXPLORER=Explorer
# ROLE_PIONEER=Pioneer
# ROLE_ENTERPRISE_ALIAS=Enterprise
# ROLE_TEAM=Team
# ROLE_MEMBER=Member
# ROLE_FOUNDER=Founder

# Ollama (optional — only if using local LLM)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=qwen3:8b

# HITL (Human-in-the-loop) secrets
# WUNDERLAND_HITL_SECRET=
# WUNDERLAND_CHAT_SECRET=
