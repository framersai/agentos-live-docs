# ============================================================
# RabbitHole Production Deployment — Environment Variables
# ============================================================
# Copy to .env and fill in values on the server.
# ============================================================

# ---------- Frontend (Next.js) ----------
ADMIN_PASSWORD=
AUTH_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
INTERNAL_API_SECRET=
RESEND_API_KEY=
EMAIL_FROM=Rabbit Hole <noreply@rabbithole.inc>
EMAIL_SUPPORT=hi@rabbithole.inc
NEXT_PUBLIC_API_URL=http://backend:3001/api
NEXT_PUBLIC_WUNDERLAND_ENABLE_CHAIN_PROOFS=false

# ---------- Backend (NestJS) ----------
PORT=3001
JWT_SECRET=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SERPER_API_KEY=
GIPHY_API_KEY=
PEXELS_API_KEY=
ELEVENLABS_API_KEY=
NEWSAPI_API_KEY=
