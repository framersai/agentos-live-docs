# Discord (optional)
# If you are running a separate discord.js gateway (recommended), do NOT enable
# the Discord channel adapter in this runtime (no DISCORD_BOT_TOKEN needed).
DISCORD_BOT_TOKEN=
# Optional (recommended): register slash commands on a single guild for faster updates.
DISCORD_GUILD_ID=

# Discord roles → billing tiers
# - Default: anyone without Pro/Team is treated as Starter.
# - Enterprise is treated as Pro (alias).
ROLE_TEAM=Team
ROLE_PRO=Pro
ROLE_ENTERPRISE_ALIAS=Enterprise

# Daily per-user quotas (reset by timezone day key)
RABBITHOLE_TZ=America/Los_Angeles
STARTER_ASK_PER_DAY=10
PRO_ASK_PER_DAY=30
STARTER_DEEPDIVE_PER_DAY=3
PRO_DEEPDIVE_PER_DAY=10

# Discord reply styling (for slash-command answers and brand embeds)
DISCORD_USE_EMBED_REPLIES=true
DISCORD_BRAND_COLOR=0x8B6914
DISCORD_BRAND_FOOTER=Powered by Rabbit Hole | rabbithole.inc

# Optional: override where the Discord extension persists lightweight state
# (quotas, notes, FAQ, trivia stats). If unset, it uses:
# - $WUNDERLAND_WORKSPACE_DIR/discord/rabbithole_discord_state.json (if available), else
# - ~/.wunderland/discord/rabbithole_discord_state.json
DISCORD_STATE_DIR=

# LLM (Ollama default)
# ollama serve  -> http://localhost:11434
# If the runtime is not on the Ollama host, use the LAN IP:
# OLLAMA_BASE_URL=http://192.168.0.68:11434
OLLAMA_BASE_URL=http://192.168.0.68:11434

# Optional fallback providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Optional tool keys (depending on which extensions you enable)
SERPER_API_KEY=
SERPAPI_API_KEY=
BRAVE_API_KEY=
# SearXNG — self-hosted metasearch (Docker: http://searxng:8080, local: http://localhost:8888)
SEARXNG_URL=
NEWSAPI_API_KEY=
GIPHY_API_KEY=
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
PIXABAY_API_KEY=
ELEVENLABS_API_KEY=
GITHUB_TOKEN=

# Weather APIs
# WeatherAPI.com (preferred provider, free tier: 1M calls/month, 3-day forecast)
# Sign up: https://www.weatherapi.com/signup.aspx
WEATHERAPI_KEY=
# Open-Meteo is used as a free fallback (no key required, 16-day forecast)
# https://open-meteo.com — no configuration needed

# Optional: set a stable HITL secret (otherwise one is generated and printed on start)
WUNDERLAND_HITL_SECRET=

# Optional: secure POST /chat behind a shared secret header (x-wunderland-chat-secret).
# If set, any gateway client (e.g. apps/rabbithole Discord bot) must use the same value.
WUNDERLAND_CHAT_SECRET=

# Feed Ingestion API — secure POST /api/feed for external scrapers (Python news bot, etc.)
# If set, the Python feed client must send this as x-wunderland-feed-secret header.
# Falls back to WUNDERLAND_CHAT_SECRET if not set.
WUNDERLAND_FEED_SECRET=
