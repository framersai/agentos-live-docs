{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@docusaurus/module-type-aliases"]
  },
  "include": ["src/**/*", "docusaurus.config.ts"],
  "exclude": [".docusaurus", "build", "docs", "node_modules"]
}
